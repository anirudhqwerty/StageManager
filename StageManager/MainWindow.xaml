<Window
    x:Class="StageManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:StageManager"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    mc:Ignorable="d"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None"
    Title="StageManager"
    Height="900"
    Width="200"
    ShowActivated="False"
    Background="Transparent"
    Name="thisWindow">

    <Window.Resources>

        <!-- Sidebar background pill -->
        <Style x:Key="SidebarPanel" TargetType="Border">
            <Setter Property="Background" Value="#CC1C1C1E"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Margin" Value="8,12,8,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hover glow effect for scene cards -->
        <DropShadowEffect x:Key="SceneCardGlow"
                          BlurRadius="16" ShadowDepth="0" Opacity="0.35" Color="#88BBFF"/>

        <!-- Per-scene card with smooth hover animations -->
        <Style x:Key="SceneCard" TargetType="Border">
            <Setter Property="Background" Value="#26FFFFFF"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="8,4,8,4"/>
            <Setter Property="Padding" Value="6,6,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.04" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.04" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#40FFFFFF" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                To="1.0" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                To="1.0" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation
                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#26FFFFFF" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Active scene card (current scene is hidden from sidebar — this is for future use) -->
        <Style x:Key="SceneCardActive" BasedOn="{StaticResource SceneCard}" TargetType="Border">
            <Setter Property="Background" Value="#55FFFFFF"/>
            <Setter Property="BorderBrush" Value="#99FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- App icon with drop shadow -->
        <Style x:Key="AppIconImage" TargetType="Image">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.6" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DWM thumbnail wrapper -->
        <Style x:Key="ThumbnailBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Fade-in animation for the sidebar -->
        <Storyboard x:Key="SidebarFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <!-- Root: transparent, full-height, click-through except on sidebar -->
    <Grid>

        <!-- Sidebar container — left-aligned, vertically centered -->
        <Border Style="{StaticResource SidebarPanel}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                MinHeight="80">

            <!-- Trigger fade-in on load -->
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SidebarFadeIn}"/>
                </EventTrigger>
            </Border.Triggers>

            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False">
                <StackPanel VerticalAlignment="Center" Margin="0,6,0,6">

                    <ItemsControl Name="scenesControl"
                                  ItemsSource="{Binding Scenes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <!-- One scene = one card -->
                                <Border Style="{StaticResource SceneCard}"
                                        Visibility="{Binding Visibility}">

                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                            <i:InvokeCommandAction
                                                Command="{Binding SwitchSceneCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                                CommandParameter="{Binding .}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>

                                    <StackPanel Orientation="Vertical">

                                        <!-- DWM live thumbnails — stacked/overlapped -->
                                        <ItemsControl ItemsSource="{Binding Windows}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Grid/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource ThumbnailBorder}">
                                                        <local:DwmThumbnail
                                                            PreviewHandle="{Binding Handle}"
                                                            MinHeight="90"
                                                            MinWidth="160"
                                                            MaxHeight="110"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- App icon row below thumbnail -->
                                        <ItemsControl HorizontalAlignment="Center"
                                                      Margin="0,2,0,2"
                                                      ItemsSource="{Binding Windows}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Image Style="{StaticResource AppIconImage}"
                                                           Source="{Binding Icon}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- System tray icon -->
        <tb:TaskbarIcon x:Name="trayIcon"
                        Visibility="Visible"
                        ToolTipText="Stage Manager"
                        IconSource="StageManager.ico"
                        MenuActivation="LeftOrRightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Opened="ContextMenu_Opened"
                             Closed="ContextMenu_Closed">
                    <MenuItem Header="Start with Windows"
                              IsCheckable="True"
                              IsChecked="{Binding StartsWithWindows}"/>
                    <MenuItem Header="Project page"
                              Click="MenuItem_ProjectPage_Click"/>
                    <Separator/>
                    <MenuItem Header="Quit"
                              Click="MenuItem_Quit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

    </Grid>
</Window>
