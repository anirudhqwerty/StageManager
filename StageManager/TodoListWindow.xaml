<Window x:Class="StageManager.TodoListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="To-Do List" Height="900" Width="300"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False"
        Background="Transparent" Topmost="True" ShowActivated="False">
    
    <Border CornerRadius="14" Margin="6,12,12,12" Background="#D0000000">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="To-Do List" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <ListBox Grid.Row="1" x:Name="TodoListBox" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Task}" IsChecked="{Binding IsCompleted}" Foreground="White" Margin="0,5">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewTaskTextBox" Grid.Column="0" KeyDown="NewTaskTextBox_KeyDown" Background="#30FFFFFF" Foreground="White" BorderThickness="0" Padding="8" VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="Add" Click="AddButton_Click" Background="#50FFFFFF" Foreground="White" BorderThickness="0" Padding="15,8" Margin="5,0,0,0" Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
