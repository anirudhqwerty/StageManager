<Window x:Class="StageManager.WorkflowPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflow" Height="660" Width="360"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False"
        Background="Transparent" Topmost="True" ShowActivated="False"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- CHECKBOX -->
        <Style x:Key="TaskCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box" Width="20" Height="20" CornerRadius="6"
                                    BorderBrush="#555" BorderThickness="1.5" Background="Transparent"
                                    VerticalAlignment="Center">
                                <Path x:Name="Tick" Data="M4,10 L8,14 L16,4"
                                      Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Stretch="Uniform"
                                      Width="11" Height="9"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="TaskText"
                                       Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center" TextWrapping="Wrap" LineHeight="19"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4CC2FF"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4CC2FF"/>
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="TaskText" Property="Foreground" Value="#555"/>
                                <Setter TargetName="TaskText" Property="TextDecorations" Value="Strikethrough"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4CC2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LIST ITEM -->
        <Style x:Key="TaskItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="#0AFFFFFF" CornerRadius="8" Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXT INPUT -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0CFFFFFF"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="12,9"
                                BorderBrush="#15FFFFFF" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CC2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACCENT BUTTON -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="#4CC2FF"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#6AD0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3AB5EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="SecondBtn" TargetType="Button">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="#BBB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="#15FFFFFF" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DELETE BUTTON (per-item) -->
        <Style x:Key="DelBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="X" Text="✕" Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}" Padding="6,2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="X" Property="Foreground" Value="#FF6B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10,0,0,0" CornerRadius="12,0,0,12"
            Background="#F2181818" BorderBrush="#20FFFFFF" BorderThickness="1,1,0,1">
        <Grid Margin="24,22,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: DATE / TIME -->
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="DateText" Foreground="#666" FontSize="12"
                           FontWeight="SemiBold" FontFamily="Segoe UI"/>
                <TextBlock x:Name="TimeText" Foreground="#F0F0F0" FontSize="32"
                           FontWeight="Light" FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ROW 1: SEPARATOR + NOTES -->
            <Border Grid.Row="1" Height="1" Background="#10FFFFFF" Margin="0,18,0,16"/>

            <StackPanel Grid.Row="2">
                <TextBlock Text="NOTES" Foreground="#666" FontSize="11"
                           FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,10"/>
                <TextBox x:Name="NotesTextBox" Style="{StaticResource InputStyle}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                         Height="100"/>
            </StackPanel>

            <!-- ROW 3: SEPARATOR -->
            <Border Grid.Row="3" Height="1" Background="#10FFFFFF" Margin="0,16,0,16"/>

            <!-- ROW 4: TO-DO (fills remaining space) -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Todo header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TO-DO" Foreground="#666" FontSize="11"
                               FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TaskCountText" Grid.Column="2" Foreground="#555"
                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>

                <!-- Todo list -->
                <ListBox Grid.Row="1" x:Name="TodoListBox" Background="Transparent"
                         BorderThickness="0" Margin="0,10,0,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource TaskItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="Row">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="{Binding Task}" IsChecked="{Binding IsCompleted}"
                                          Style="{StaticResource TaskCheck}"/>
                                <Button Grid.Column="1" x:Name="DelBtn" Click="DeleteTask_Click"
                                        Style="{StaticResource DelBtn}" Visibility="Collapsed"/>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="Row" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="DelBtn" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Add task row -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewTaskTextBox" KeyDown="NewTaskTextBox_KeyDown"
                             Style="{StaticResource InputStyle}"/>
                    <Button Grid.Column="1" Content="+" Click="AddTask_Click"
                            Style="{StaticResource AccentBtn}" Padding="12,8"
                            FontSize="18" Margin="8,0,0,0"/>
                </Grid>
            </Grid>

            <!-- ROW 5: SEPARATOR -->
            <Border Grid.Row="5" Height="1" Background="#10FFFFFF" Margin="0,16,0,16"/>

            <!-- ROW 6: FOCUS TIMER -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="FOCUS" Foreground="#666" FontSize="11"
                           FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBlock x:Name="TimerText" Text="25:00" Foreground="#F0F0F0"
                           FontSize="36" FontWeight="Light" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,10,0,4"/>
                <Border Height="3" Background="#10FFFFFF" CornerRadius="2" Margin="0,0,0,14">
                    <Border x:Name="TimerProgress" Background="#4CC2FF"
                            CornerRadius="2" HorizontalAlignment="Left"/>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="StartPauseBtn" Content="Start" Click="StartPause_Click"
                            Style="{StaticResource AccentBtn}" Padding="0,10" Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="Reset" Click="Reset_Click"
                            Style="{StaticResource SecondBtn}" Padding="0,10" Margin="4,0,0,0"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
