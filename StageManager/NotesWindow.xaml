<Window x:Class="StageManager.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notes" Height="400" Width="320"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False"
        Background="Transparent" Topmost="True" ShowActivated="False">
    
    <Border CornerRadius="14" Margin="6,12,12,12" Background="#E0FFFACE">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Quick Notes" Foreground="#333333" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBox Grid.Row="1" x:Name="NotesTextBox" AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Foreground="#222222" FontSize="15" VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Border>
</Window>
