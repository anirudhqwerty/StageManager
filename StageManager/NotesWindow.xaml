<Window x:Class="StageManager.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notes" Height="320" Width="400"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False"
        Background="Transparent" Topmost="True" ShowActivated="False"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style x:Key="NoteArea" TargetType="TextBox">
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="CaretBrush" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="14,12"
                                BorderBrush="#18FFFFFF" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CC2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="8,0,8,8" CornerRadius="0,0,12,12"
            Background="#F2202020" BorderBrush="#22FFFFFF" BorderThickness="1,0,1,1">
        <Grid Margin="22,18,22,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,2,0,0">
                <TextBlock Text="Quick Notes" Foreground="White" FontSize="21" FontWeight="SemiBold"
                           FontFamily="Segoe UI"/>
                <Border Height="2.5" Background="#4CC2FF" HorizontalAlignment="Left"
                        Width="30" Margin="0,8,0,0" CornerRadius="2"/>
            </StackPanel>

            <!-- Separator -->
            <Border Grid.Row="1" Height="1" Background="#12FFFFFF" Margin="0,16,0,14"/>

            <!-- Text Area -->
            <TextBox Grid.Row="2" x:Name="NotesTextBox" Style="{StaticResource NoteArea}"/>
        </Grid>
    </Border>
</Window>
